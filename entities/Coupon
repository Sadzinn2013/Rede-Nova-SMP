{
  "name": "Coupon",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "C\u00f3digo do cupom (ex: DESCONTO10)"
    },
    "discount_type": {
      "type": "string",
      "enum": [
        "percent",
        "fixed"
      ],
      "description": "Tipo de desconto: porcentagem ou valor fixo"
    },
    "discount_value": {
      "type": "number",
      "description": "Valor do desconto (ex: 10 para 10% ou R$10)"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Se o cupom est\u00e1 ativo"
    },
    "uses_left": {
      "type": "number",
      "description": "Quantos usos restam (-1 = ilimitado)"
    }
  },
  "required": [
    "code",
    "discount_type",
    "discount_value"
  ]
}